/gradlew text eol=lf
*.bat text eol=crlf

# Normalize all text files to LF when stored in git
* text=auto eol=lf

# Kotlin / JVM source files
*.kt         text eol=lf
*.kts        text eol=lf
*.java       text eol=lf

# Config files
*.xml        text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.json       text eol=lf
*.properties text eol=lf
*.toml       text eol=lf
*.md         text eol=lf
*.sql        text eol=lf
*.sh         text eol=lf

# Gradle wrapper scripts must always be LF
gradlew      text eol=lf

# Binary files — git must never touch these
*.jar        binary
*.class      binary
*.png        binary
*.jpg        binary
*.jpeg       binary
